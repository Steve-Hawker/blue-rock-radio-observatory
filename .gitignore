# Blue Rock Radio Observatory — .gitignore
# Files and patterns that Git should never track

# =============================================================
# SECURITY — credentials, tokens, keys
# These must NEVER be committed to any repository
# =============================================================
*.rtf
*.key
*.pem
*.p12
*.pfx
*token*
*password*
*secret*
*credential*
*apikey*
*.env

# =============================================================
# macOS system files
# =============================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# =============================================================
# Temporary and backup files
# =============================================================
*.tmp
*.bak
*.swp
*.swo
~*
*~

# =============================================================
# Large data files
# Raw observation data belongs in a separate storage location,
# not in this repository. Log the file path in session logs.
# =============================================================
*.fits
*.FITS
*.raw
*.wav
*.sigmf-data
*.bin
*.dat

# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# =============================================================
# GNU Radio
# =============================================================
*.pyc

# =============================================================
# Editor files
# =============================================================
.vscode/settings.json
*.sublime-project
*.sublime-workspace
